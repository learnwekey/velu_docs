{
  "$schema": "https://veludocs.com/velu.schema.json",
  "name": "Velu Documentation",
  "colors": {
    "primary": "#dc143c"
  },
  "favicon": "/favicon.svg",
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "mcp",
