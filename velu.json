                "pages": [
                  "getting-started/install-velu",
                  "getting-started/local-preview",
                  "getting-started/validate"
                ]
              }
            ]
          },
          {
            "group": "Customize",
            "icon": "sliders-horizontal",
            "pages": [
              "essentials/configuration",
              "essentials/docs-site-structure",
              "essentials/appearance",
              "essentials/header-footer",
              "essentials/seo-social"
            ]
          },
          {
            "group": "Organize",
            "icon": "route",
            "pages": [
              "essentials/navigation",
              "essentials/navigation-switchers"
            ]
          },
          {
            "group": "Create Content",
            "icon": "pen-line",
            "pages": [
              "essentials/content-overview",
              "essentials/pages",
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-content",
              {
                "group": "Components",
                "pages": [
                  "components/overview",
                  "components/emphasis",
                  "components/layout",
                  "components/code-ai",
                  "components/media-updates"
                ]
              },
              "getting-started/deployment"
            ]
          },
          {
            "group": "AI-native Features",
            "icon": "sparkles",
            "pages": [
              "ai-native/ask-velu",
              "ai-native/search",
              "ai-native/contextual-actions",
              "ai-native/llms",
              "ai-native/mcp",
              "ai-native/page-feedback"
            ]
          },
          {
            "group": "AI Tools",
            "icon": "sparkles",
            "pages": [
              "ai-tools/claude-code",
              "ai-tools/cursor"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "terminal",
        "openapi": "/openapi.json",
        "groups": [
          {
            "group": "API Documentation",
            "pages": [
              "api-reference/introduction",
              "api-reference/openapi",
              "api-reference/api-playground"
